{
  "name": "@ancientbag/react-typewriter",
  "version": "1.0.0",
  "description": "React hooks for typewriter text animation effects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/react": "^19.1.0"
  },
  "keywords": [
    "react",
    "typewriter",
    "animation",
    "hook",
    "smart",
    "text-effect"
  ],
  "license": "MIT",
  "author": "Denis Timashev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ancientbag/react-typewriter"
  }
}
